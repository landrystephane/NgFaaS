diff --git a/nginx.conf b/nginx.conf
new file mode 100644
index 0000000..322a009
--- /dev/null
+++ b/nginx.conf
@@ -0,0 +1,51 @@
+# ==============================================================================
+# Configuration NGINX pour le Cluster ngFaaS (Architecture Mimir)
+# ==============================================================================
+# Ce fichier configure NGINX comme Load Balancer frontal.
+# Il recoit les requetes des utilisateurs (sur le port 80) et les distribue
+# equitablement entre les differentes instances de Data Planes disponibles.
+
+# Definition du groupe de Data Planes (Le cluster backend)
+# L'administrateur systeme peut ajouter/retirer des lignes ici en fonction
+# du nombre d'instances de Data Planes lancees sur le serveur.
+upstream ngfaas_dataplanes {
+    # Stratégie par défaut : Round Robin (tour de role)
+    # On peut utiliser 'least_conn;' pour envoyer a l'instance ayant le moins de requetes actives.
+
+    server 127.0.0.1:8080; # Data Plane Instance 1
+    server 127.0.0.1:8081; # Data Plane Instance 2
+    server 127.0.0.1:8082; # Data Plane Instance 3 (A decommenter si on en lance 3)
+}
+
+server {
+    listen 80;
+    server_name ngfaas.ecole.fr localhost; # Le nom de domaine ou l'IP du serveur
+
+    # Configuration generale pour optimiser la latence (FaaS)
+    # On desactive la mise en buffer pour que les reponses synchrones
+    # arrivent le plus vite possible a l'utilisateur.
+    proxy_buffering off;
+    proxy_request_buffering off;
+
+    # On maintient la connexion en vie avec les Data Planes
+    # pour eviter le cout de la poignee de main TCP (TCP Handshake) a chaque requete.
+    keepalive_timeout 65;
+
+    # Point d'entree principal de la plateforme FaaS
+    location / {
+        # Redirection vers notre groupe de Data Planes
+        proxy_pass http://ngfaas_dataplanes;
+
+        # Transfert des en-tetes d'origine pour que le Data Plane
+        # connaisse l'IP reelle de l'utilisateur.
+        proxy_set_header Host $host;
+        proxy_set_header X-Real-IP $remote_addr;
+        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+        proxy_set_header X-Forwarded-Proto $scheme;
+
+        # Gestion des Timeouts (Si un Data Plane crash, NGINX passe au suivant apres 2 secondes)
+        proxy_connect_timeout 2s;
+        proxy_send_timeout 30s;
+        proxy_read_timeout 30s;
+    }
+}
