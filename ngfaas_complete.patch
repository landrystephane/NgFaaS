+// ---------------------------------------------------------
+// 2. DÉFINITION DES MESSAGES (Structures de données)
+// ---------------------------------------------------------
+
+// RegisterWorkerRequest contient les infos qu'un Worker envoie quand il s'enregistre
+message RegisterWorkerRequest {
+    // Chaque champ a un numéro unique (= 1, = 2) utilisé pour compresser les données
+    string worker_id = 1;
+    string ip_address = 2;
+    int32 port = 3;
+    // On pourrait ajouter d'autres infos plus tard : CPU disponible, RAM, etc.
+}
+
+// RegisterDataPlaneRequest contient les infos d'un DataPlane qui s'enregistre
+message RegisterDataPlaneRequest {
+    string dataplane_id = 1;
+    string ip_address = 2;
+}
+
+// RegisterResponse est la réponse standard renvoyée par le Controller
+message RegisterResponse {
+    bool success = 1;
+    string message = 2;
+}
