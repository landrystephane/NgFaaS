+
+// ControllerService est le "contrat" que le Controller doit respecter.
+// Il expose les méthodes que les autres composants (DataPlane, Worker) peuvent appeler.
+service ControllerService {
+    // RegisterWorker permet à un Worker de s'annoncer auprès du Controller (Flèche 5 du schéma)
+    rpc RegisterWorker(RegisterWorkerRequest) returns (RegisterResponse);
+
+    // RegisterDataPlane permet à un Data Plane de s'annoncer (Flèche 3 du schéma)
+    rpc RegisterDataPlane(RegisterDataPlaneRequest) returns (RegisterResponse);
+}
